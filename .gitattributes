# Ensure AI conversation logs are tracked as text
.ai-conversations/** text
.claude/** text
.cursor/** text
.aider.chat.history.md text

# Force LF line endings for shell scripts so Docker on Linux parses shebangs correctly
# Without this, core.autocrlf=true on Windows checks out bin/ files with CRLF,
# causing '/usr/bin/env: bash\r: No such file or directory' at container startup.
bin/* text eol=lf
